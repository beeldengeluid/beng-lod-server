###  http://www.beeldengeluid.nl/schema/hasMainTitle
nisv:hasMainTitle rdfs:subPropertyOf schema:name . 


###  http://www.beeldengeluid.nl/schema/hasMusicStyle
nisv:hasMusicStyle rdfs:subPropertyOf schema:genre .


###  http://www.beeldengeluid.nl/schema/hasNationality 
nisv:hasNationality rdfs:subPropertyOf schema:contributor . # we could consider modelling Nationality differently in our schema, to make it more role-like. Basically it is about a contributor with a given role from a certain country

###  http://www.beeldengeluid.nl/schema/hasOrganisation
# This is a strange one, because due to the Roles in schema, hasOrganisation needs to match the
# roles. E.g where we have <x> nisv:hasFunder <y> . <y> nisv:hasOrganisation <z>, schema.org
# has <x> schema:funder <y> . <y> schema:funder <z>. 
# This gets even more complicated given that 'executive' in NISV maps to 'byArtist' in schema
# but in NISV it can be either a person or an organisation, so we need to relate byArtist to hasOrganisation too
# The schema.org properties are also more specific in this case, so we turn the rdfs:subPropertyOf property around
schema:funder rdfs:subPropertyOf nisv:hasOrganisation .
schema:sponsor rdfs:subPropertyOf nisv:hasOrganisation .
schema:byArtist rdfs:subPropertyOf nisv:hasOrganisation . # for executive
schema:mentions rdfs:subPropertyOf nisv:hasOrganisation . # for names
schema:productionCompany rdfs:subPropertyOf nisv:hasOrganisation . # for producer


###  http://www.beeldengeluid.nl/schema/hasOriginalCreator
nisv:hasOriginalCreator rdfs:subPropertyOf schema:creator .


###  http://www.beeldengeluid.nl/schema/hasPerson
# This is a strange one, because due to the Roles in schema, hasPerson needs to match the
# roles. E.g where we have <x> nisv:hasSpeaker <y> . <y> nisv:hasPerson <z>, schema.org
# has <x> schema:contributor <y> . <y> schema:contributor<z>. 
# The schema.org properties are also more specific in this case, so we turn the rdfs:subPropertyOf property around

schema:byArtist rdfs:subPropertyOf nisv:hasPerson . # for executive
schema:mentions rdfs:subPropertyOf nisv:hasPerson . # for personnames
schema:actor rdfs:subPropertyOf nisv:hasPerson .  # for cast
schema:creator rdfs:subPropertyOf nisv:hasPerson . # for creator and original creator
schema:contributor rdfs:subPropertyOf nisv:hasPerson . # for speaker


###  http://www.beeldengeluid.nl/schema/hasProducer
nisv:hasProducer rdfs:subPropertyOf schema:producer


###  http://www.beeldengeluid.nl/schema/hasProductionCountry
nisv:hasProductionCountry rdfs:subPropertyOf schema:countryOfOrigin


