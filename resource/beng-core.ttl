###  http://data.rdlabs.beeldengeluid.nl/schema/Nationality
nisv:Nationality rdf:type owl:Class ;
                 rdfs:subClassOf nisv:EntityInRole ;
                 rdfs:comment "Nationaliteit die voorkomt in een audiovisuele entiteit en de functie van de persoon die tot die nationaliteit behoord"@nl ,
                              "Nationality occurring in an audiovisual object and the role of the person of that nationality"@en ;
                 rdfs:label "Nationaliteit"@nl ,
