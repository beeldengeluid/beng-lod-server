                                "Original Artist"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/Person
nisv:Person rdf:type owl:Class ;
            rdfs:subClassOf nisv:ActingEntity ;
            rdfs:comment "A person. Comes from the GTAA Persoonsnamen scheme"@en ;
            rdfs:label "Person"@en ,
                       "Persoon"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/PlayableAudioVisualObject
nisv:PlayableAudioVisualObject rdf:type owl:Class ;
                               rdfs:subClassOf skos:Concept ;
                               rdfs:comment "Audiovisueel object dat een fysieke drager is of een link heeft naar een fysieke drager waarop het afgespeeld kan worden. Programma's en Programma-onderdelen zijn hier voorbeelden van, ze hebben een drager aan hen gelinkt die het eigenlijke audiovisuele inhoud bevat."@nl ,
                                            "audiovisual object that is a physical carrier or has a link to a physical carrier from which it can be played. Programmes and Programme sections are examples of this, they can have a carrier linked to them containing actual audiovisual content"@en ;
                               rdfs:label "Afspeelbare audiovisuele object"@nl ,
                                          "Playable audiovisual object"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/Producer
nisv:Producer rdf:type owl:Class ;
              rdfs:subClassOf nisv:EntityInRole ;
              rdfs:comment "Producent van enkel audiovisuele entiteit"@nl ,
                           "Producer of an individual audiovisual object"@en ;
              rdfs:label "Producent"@nl ,
                         "Producer"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/Program
nisv:Program rdf:type owl:Class ;
             rdfs:subClassOf nisv:ArchiveMetadataObject ,
