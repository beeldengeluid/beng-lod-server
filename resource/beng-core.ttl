@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix nisv: <http://data.rdlabs.beeldengeluid.nl/schema/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://dublincore.org/documents/2010/10/11/dcmi-terms#> .
@base <http://www.w3.org/2002/07/owl#> .

[ rdf:type owl:Ontology
 ] .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://data.rdlabs.beeldengeluid.nl/schema/hasBroadcastStation
nisv:hasBroadcastStation rdf:type owl:ObjectProperty ;
                         rdfs:domain nisv:PublicationEvent ;
                         rdfs:range nisv:BroadcastStation ;
                         rdfs:label "has broadcast station (network, channel)"@en ,
                                    "heeft zender"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasBroadcaster
nisv:hasBroadcaster rdf:type owl:ObjectProperty ;
                    rdfs:domain nisv:PublicationEvent ;
                    rdfs:range nisv:Broadcaster ;
                    rdfs:label "has broadcaster"@en ,
                               "heeft zendgemachtigde"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCarrier
nisv:hasCarrier rdf:type owl:ObjectProperty ;
                rdfs:domain nisv:PlayableAudioVisualObject ;
                rdfs:range nisv:Carrier ;
                rdfs:label "has carrier" ,
                           "heeft drager"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCast
nisv:hasCast rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf nisv:hasEntityInRole ;
             rdfs:domain nisv:ArchiveMetadataObject ;
             rdfs:range nisv:Cast ;
             rdfs:label "has cast" ,
                        "heeft cast"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasContractor
nisv:hasContractor rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf nisv:hasEntityInRole ;
                   rdfs:domain nisv:ArchiveMetadataObject ;
                   rdfs:range nisv:Contractor ;
                   rdfs:label "has contractor" ,
                              "heeft opdrachtgever"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCountry
nisv:hasCountry rdf:type owl:ObjectProperty ;
                rdfs:domain nisv:Nationality ;
                rdfs:range nisv:Location ;
                rdfs:label "has country"@en ,
                           "heeft land"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCreator
nisv:hasCreator rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf nisv:hasEntityInRole ;
                rdfs:domain nisv:ArchiveMetadataObject ;
                rdfs:range nisv:Creator ;
                rdfs:label "has creator" ,
                           "heeft maker"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasEntity
nisv:hasEntity rdf:type owl:ObjectProperty ;
               rdfs:domain nisv:EntityInRole ;
               rdfs:range nisv:ActingEntity ;
               rdfs:label "has entity"@en ,
                          "heeft entiteit"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasEntityInRole
nisv:hasEntityInRole rdf:type owl:ObjectProperty ;
                     rdfs:domain nisv:ArchiveMetadataObject ;
                     rdfs:range nisv:EntityInRole ;
                     rdfs:label "has an entity in a role"@en ,
                                "heeft een entiteit in een rol"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasExecutive
nisv:hasExecutive rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf nisv:hasEntityInRole ;
                  rdfs:domain nisv:ArchiveMetadataObject ;
                  rdfs:range nisv:EntityInRole ;
                  rdfs:comment "the executive can be either a person or an organisation"@en ;
                  rdfs:label "has executive" ,
                             "heeft uitvoerende"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasFunder
nisv:hasFunder rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf nisv:hasEntityInRole ;
               rdfs:domain nisv:ArchiveMetadataObject ;
               rdfs:range nisv:Funder ;
               rdfs:label "has funder" ,
                          "heeft subsidiegever"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasGenre
nisv:hasGenre rdf:type owl:ObjectProperty ;
              rdfs:domain nisv:ArchiveMetadataObject ;
              rdfs:range nisv:Genre ;
              rdfs:label "has genre"@en ,
                         "heeft genre"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasLocation
nisv:hasLocation rdf:type owl:ObjectProperty ;
                 rdfs:domain nisv:ArchiveMetadataObject ;
                 rdfs:range nisv:Location ;
                 rdfs:label "has location"@en ,
                            "heeft locatie"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasMainTitle
nisv:hasMainTitle rdf:type owl:ObjectProperty ;
                  rdfs:range nisv:Title ;
                  rdfs:label "has main title"@en ,
                             "heeft hoofdtitel"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasMusicStyle
nisv:hasMusicStyle rdf:type owl:ObjectProperty ;
                   rdfs:domain nisv:ArchiveMetadataObject ;
                   rdfs:range nisv:MusicStyle ;
                   rdfs:label "has music style"@en ,
                              "heeft muziekstijl"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasNationality
nisv:hasNationality rdf:type owl:ObjectProperty ;
                    rdfs:domain nisv:ArchiveMetadataObject ;
                    rdfs:range nisv:Nationality ;
                    rdfs:label "has nationality" ,
                               "heeft nationaliteit"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasOrganisation
nisv:hasOrganisation rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf nisv:hasEntity ;
                     rdfs:range nisv:Organisation ;
                     rdfs:label "has organisation"@en ,
                                "heeft organisatie"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasOriginalCreator
nisv:hasOriginalCreator rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf nisv:hasEntityInRole ;
                        rdfs:domain nisv:ArchiveMetadataObject ;
                        rdfs:range nisv:OriginalCreator ;
                        rdfs:label "has original creator" ,
                                   "heeft oorspronkelijke maker"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasPerson
nisv:hasPerson rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf nisv:hasEntity ;
               rdfs:range nisv:Person ;
               rdfs:label "has person"@en ,
                          "heeft persoon"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasProducer
nisv:hasProducer rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf nisv:hasEntityInRole ;
                 rdfs:domain nisv:ArchiveMetadataObject ;
                 rdfs:range nisv:Producer ;
                 rdfs:label "has producer" ,
                            "heeft producent"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasProductionCountry
nisv:hasProductionCountry rdf:type owl:ObjectProperty ;
                          rdfs:domain nisv:ArchiveMetadataObject ;
                          rdfs:range nisv:Location ;
                          rdfs:label "has production country" ,
                                     "heeft productieland"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasPublication
nisv:hasPublication rdf:type owl:ObjectProperty ;
                    rdfs:domain nisv:Program ;
                    rdfs:range nisv:PublicationEvent ;
                    rdfs:label "has publication" ,
                               "heeft publicatie"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasRecording
nisv:hasRecording rdf:type owl:ObjectProperty ;
                  rdfs:domain nisv:PlayableAudioVisualObject ;
                  rdfs:range nisv:RecordingEvent ;
                  rdfs:label "has recording" ,
                             "heeft opname"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasSpeaker
nisv:hasSpeaker rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf nisv:hasEntityInRole ;
                rdfs:domain nisv:ArchiveMetadataObject ;
                rdfs:range nisv:Speaker ;
                rdfs:label "has speaker" ,
                           "heeft spreker"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasSponsor
nisv:hasSponsor rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf nisv:hasEntityInRole ;
                rdfs:domain nisv:ArchiveMetadataObject ;
                rdfs:range nisv:Sponsor ;
                rdfs:label "has sponsor" ,
                           "heeft sponsor"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasSubTitle
nisv:hasSubTitle rdf:type owl:ObjectProperty ;
                 rdfs:domain nisv:ArchiveMetadataObject ;
                 rdfs:range nisv:Title ;
                 rdfs:comment "This is a secondary title. Should not be confused with subtitling" ;
                 rdfs:label "has sub title"@en ,
                            "heeft tweede titel"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasSubject
nisv:hasSubject rdf:type owl:ObjectProperty ;
                rdfs:domain nisv:ArchiveMetadataObject ;
                rdfs:range nisv:Subject ;
                rdfs:label "has subject"@en ,
                           "heeft onderwerp"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/isPartOfProgram
nisv:isPartOfProgram rdf:type owl:ObjectProperty ;
                     rdfs:domain nisv:SceneDescription ;
                     rdfs:range nisv:Program ;
                     rdfs:label "is deel van programma"@nl ,
                                "is part of program"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/isPartOfSeason
nisv:isPartOfSeason rdf:type owl:ObjectProperty ;
                    rdfs:domain nisv:Program ;
                    rdfs:range nisv:Season ;
                    rdfs:label "is deel van seizoen"@nl ,
                               "is part of season"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/isPartOfSeries
nisv:isPartOfSeries rdf:type owl:ObjectProperty ;
                    rdfs:domain nisv:ArchiveMetadataObject ;
                    rdfs:range nisv:Series ;
                    rdfs:label "is deel van reeks"@nl ,
                               "is part of series"@en .


###  http://www.beeldengeluid.nl/schema/hasCurrentBroadcaster
<http://www.beeldengeluid.nl/schema/hasCurrentBroadcaster> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain nisv:Program ;
                                                           rdfs:range nisv:Broadcaster ;
                                                           rdfs:comment "wat is het verschil tussen dit en de 'originele' zendgemachtigde?"@nl ,
                                                                        "what is the difference between this and the 'original' broadcaster?"@en ;
                                                           rdfs:label "has current broadcaster"@en ,
                                                                      "heeft huidige zendgemachtigde"@nl .


#################################################################
#    Data properties
#################################################################

###  http://data.rdlabs.beeldengeluid.nl/schema/hasAdditionalInformation
nisv:hasAdditionalInformation rdf:type owl:DatatypeProperty ;
                              rdfs:range xsd:string ;
                              rdfs:label "has additional information"@en ,
                                         "heeft toelichting"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCarrierNumber
nisv:hasCarrierNumber rdf:type owl:DatatypeProperty ;
                      rdfs:domain nisv:Carrier ;
                      rdfs:range xsd:string ;
                      rdfs:label "has carrier number"@en ,
                                 "heeft dragernummer"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCarrierType
nisv:hasCarrierType rdf:type owl:DatatypeProperty ;
                    rdfs:domain nisv:Carrier ;
                    rdfs:range xsd:string ;
                    rdfs:comment "de dragertype, bijv. MXF"@nl ,
                                 "the type of the carrier, e.g. MXF"@en ;
                    rdfs:label "has carrier type"@en ,
                               "heeft dragertype"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCategory
nisv:hasCategory rdf:type owl:DatatypeProperty ;
                 rdfs:domain nisv:Program ;
                 rdfs:range xsd:string ;
                 rdfs:comment "de categorie waaronder dit archiefobject valt, bijv. 'sports', 'youth programmes' (jeugdprogramma's )"@nl ,
                              "the category that this archive object falls into, e.g. 'sports', 'youth programmes'"@en ;
                 rdfs:label "has category"@en ,
                            "heeft categorie"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCharacter
nisv:hasCharacter rdf:type owl:DatatypeProperty ;
                  rdfs:domain nisv:Cast ;
                  rdfs:range xsd:string ;
                  rdfs:comment "de karakter dat deze acteur speelt in dit archiefobject"@nl ,
                               "the character played by this actor in this archive object"@en ;
                  rdfs:label "has character"@en ,
                             "heeft karakter"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCollectionTitle
nisv:hasCollectionTitle rdf:type owl:DatatypeProperty ;
                        rdfs:domain nisv:Carrier ;
                        rdfs:range xsd:string ;
                        rdfs:comment "de titel van de collectie waar deze drager toe behoort"@nl ,
                                     "the title of the collection to which this carrier belongs"@en ;
                        rdfs:label "has collection title"@en ,
                                   "heeft collectietitel"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasColour
nisv:hasColour rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string ;
               rdfs:comment "de kleur van dit archief object"@nl ,
                            "the colour of this archive object"@en ;
               rdfs:label "has colour"@en ,
                          "heeft kleur"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasCreationDate
nisv:hasCreationDate rdf:type owl:DatatypeProperty ;
                     rdfs:domain nisv:Carrier ;
                     rdfs:range xsd:dateTime ;
                     rdfs:comment "de datum waarop de drager is gemaakt"@nl ,
                                  "the date on which the carrier was created"@en ;
                     rdfs:label "has creation date"@en ,
                                "heeft creatiedatum"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasDatePrecision
nisv:hasDatePrecision rdf:type owl:DatatypeProperty ;
                      rdfs:domain nisv:Activity ;
                      rdfs:range xsd:string ;
                      rdfs:comment "de precisie waarme het datum is bekend"@nl ,
                                   "the precision with which the date is known"@en ;
                      rdfs:label "has date precision"@en ,
                                 "heeft datum precisie"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasDescription
nisv:hasDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain nisv:ArchiveMetadataObject ;
                    rdfs:range xsd:string ;
                    rdfs:comment "a description of the archive object"@en ,
                                 "een beschrijving van het archiefobject"@nl ;
                    rdfs:label "has description"@en ,
                               "heeft beschrijving"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasDistributionChannel
nisv:hasDistributionChannel rdf:type owl:DatatypeProperty ;
                            rdfs:domain nisv:PublicationEvent ;
                            rdfs:range xsd:string ;
                            rdfs:comment "de type distributiekanaal gebruikt om de publicatie te publiceren, bijv. 'televisie',  'radio'"@nl ,
                                         "the type of distribution channel used to publish the publication, e.g. 'televisie' or 'radio'"@en ;
                            rdfs:label "has distribution channel"@en ,
                                       "heeft distributiekanaal"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasDuration
nisv:hasDuration rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:long ;
                 rdfs:comment "de tijdslengte van dit archiefobject"@nl ,
                              "the duration of this archive object"@en ;
                 rdfs:label "has duration"@en ,
                            "heeft tijdslengte"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasDurationAnnotation
nisv:hasDurationAnnotation rdf:type owl:DatatypeProperty ;
                           rdfs:range xsd:string ;
                           rdfs:comment "additional information about the value filled in for the duration"@en ,
                                        "toelicht op de invulwaarde van de duratie"@nl ;
                           rdfs:label "has duration annotation"@en ,
                                      "heeft tijdslengte annotatie"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasEndDate
nisv:hasEndDate rdf:type owl:DatatypeProperty ;
                rdfs:domain nisv:Activity ;
                rdfs:range xsd:dateTime ;
                rdfs:comment "het einddatum van deze activiteit"@nl ,
                             "the final date of this activity"@en ;
                rdfs:label "has end date"@en ,
                           "heeft einddatum"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasEndTime
nisv:hasEndTime rdf:type owl:DatatypeProperty ;
                rdfs:domain nisv:PublicationEvent ;
                rdfs:range xsd:string ;
                rdfs:comment "de eindtijd van deze publicatie"@nl ;
                rdfs:label "has end time"@en ,
                           "heeft eindtijd"@nl ,
                           "the end time of this publication"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasEpisodeNumber
nisv:hasEpisodeNumber rdf:type owl:DatatypeProperty ;
                      rdfs:domain nisv:Program ;
                      rdfs:range xsd:long ;
                      rdfs:comment "het afleveringsnummer van dit programma"@nl ,
                                   "the episode number of this programme"@en ;
                      rdfs:label "has episode number"@en ,
                                 "heeft afleveringsnummer"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasLink
nisv:hasLink rdf:type owl:DatatypeProperty ;
             rdfs:domain nisv:ArchiveMetadataObject ;
             rdfs:range xsd:string ;
             rdfs:comment "link naar een website gerelateerd aan het archiefobject"@nl ,
                          "link to a website relating to the archive object"@en ;
             rdfs:label "has link"@en ,
                        "heeft link"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasMaterialType
nisv:hasMaterialType rdf:type owl:DatatypeProperty ;
                     rdfs:domain nisv:Program ;
                     rdfs:range xsd:string ;
                     rdfs:comment "de type van de programma/foto/object bijv. audio, video, foto"@nl ,
                                  "the type of the programme/photo/object, e.g. video, audio, foto"@en ;
                     rdfs:label "has material type"@en ,
                                "heeft type materiaal"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasMetadataStatus
nisv:hasMetadataStatus rdf:type owl:DatatypeProperty ;
                       rdfs:range xsd:string ;
                       rdfs:comment "de status van de metadata bijv. 'approved'"@nl ,
                                    "the status of the metadata e.g. approved"@en ;
                       rdfs:label "has metadata status"@en ,
                                  "heeft metadata status"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasNumberOfEpisodes
nisv:hasNumberOfEpisodes rdf:type owl:DatatypeProperty ;
                         rdfs:domain nisv:ArchiveMetadataObject ;
                         rdfs:range xsd:long ;
                         rdfs:comment "het aantal afleveringen in dit series/seizoen"@nl ,
                                      "the number of episodes in this series/season"@en ;
                         rdfs:label "has number of episodes"@en ,
                                    "heeft aantal afleveringen"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasProductYear
nisv:hasProductYear rdf:type owl:DatatypeProperty ;
                    rdfs:domain nisv:RecordingEvent ;
                    rdfs:range xsd:dateTime ;
                    rdfs:comment "het jaar waarin de opname is gebeurd"@nl ,
                                 "the year in which the recording was produced"@en ;
                    rdfs:label "has production year"@en ,
                               "heeft productiejaar"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasRecordingLocation
nisv:hasRecordingLocation rdf:type owl:DatatypeProperty ;
                          rdfs:domain nisv:ArchiveMetadataObject ;
                          rdfs:range xsd:string ;
                          rdfs:comment "de locatie waarop opname gebeurde voor dit archiefobject"@nl ,
                                       "the location at which recording occurred for this archive object"@en ;
                          rdfs:label "has recording location"@en ,
                                     "heeft opnamelocatie"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasRole
nisv:hasRole rdf:type owl:DatatypeProperty ;
             rdfs:domain nisv:EntityInRole ;
             rdfs:range xsd:string ;
             rdfs:comment "de rol waarin deze entiteit heeft bijgedragen aan de productie, bijv. 'schrijver'"@nl ,
                          "the role in which this entity has contributed to the archive object, e.g. 'schrijver' (writer)"@en ;
             rdfs:label "has role"@en ,
                        "heeft rol"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasSeasonNumber
nisv:hasSeasonNumber rdf:type owl:DatatypeProperty ;
                     rdfs:domain nisv:Season ;
                     rdfs:range xsd:string ;
                     rdfs:label "has season number"@en ,
                                "heeft seizoensnummer"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasSortDate
nisv:hasSortDate rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:date ;
                 rdfs:comment "het datum waarop dit archiefobject moet worden gesorteerd. Dit is anders per type archiefobject. Bijvoorbeeld, voor een televisieprogramme het is het datum van de eerste uitzending."@nl ,
                              "the date by which this archive object should be sorted. The choice of date differs per type of archive object. E.g. for a TV programme, it is the date the programme is first broadcast."@en ;
                 rdfs:label "has sort date"@en ,
                            "heeft sorteerdatum"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasStartDate
nisv:hasStartDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain nisv:Activity ;
                  rdfs:range xsd:date ;
                  rdfs:comment "het datum waarop deze activiteit is begonnen"@nl ,
                               "the date on which this activity started"@en ;
                  rdfs:label "has start date"@en ,
                             "heeft begindatum"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasStartTime
nisv:hasStartTime rdf:type owl:DatatypeProperty ;
                  rdfs:domain nisv:PublicationEvent ;
                  rdfs:range xsd:long ;
                  rdfs:comment "de tijd waarop deze publicatie begon"@nl ,
                               "the time at which this publication started"@en ;
                  rdfs:label "has start time"@en ,
                             "heeft begintijd"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasSummary
nisv:hasSummary rdf:type owl:DatatypeProperty ;
                rdfs:domain nisv:ArchiveMetadataObject ;
                rdfs:range xsd:string ;
                rdfs:comment "a short summary of this archive object"@en ,
                             "de korte samenvatting van dit archiefobject"@nl ;
                rdfs:label "has summary"@en ,
                           "heeft samenvatting"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasTag
nisv:hasTag rdf:type owl:DatatypeProperty ;
            rdfs:domain nisv:ArchiveMetadataObject ;
            rdfs:range xsd:string ;
            rdfs:comment "a non-thesaurus tag"@en ,
                         "een niet-thesaurus tag"@nl ;
            rdfs:label "has tag"@en ,
                       "heeft tag"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasTheme
nisv:hasTheme rdf:type owl:DatatypeProperty ;
              rdfs:domain nisv:ArchiveMetadataObject ;
              rdfs:range xsd:string ;
              rdfs:comment "het brede thema van dit archiefobject, bijv. 'koninklijk huis'"@nl ,
                           "the broad theme of this archief object, e.g. 'koninklijk huis' (the royal family)"@en ;
              rdfs:label "has theme"@en ,
                         "heeft thema"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasTitleText
nisv:hasTitleText rdf:type owl:DatatypeProperty ;
                  rdfs:domain nisv:Title ;
                  rdfs:range xsd:string ;
                  rdfs:comment "de echte tekst van de titel, in tegenstelling tot het Title object dat deze tekst en de type titel bevat"@nl ,
                               "the actual text of the title, as opposed to the Title object that contains this text and the title type"@en ;
                  rdfs:label "has title text"@en ,
                             "heeft titeltekst"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/hasTitleType
nisv:hasTitleType rdf:type owl:DatatypeProperty ;
                  rdfs:domain nisv:Title ;
                  rdfs:range xsd:string ;
                  rdfs:comment "de type van de titel. Meestal is dit simpelweg 'gegeven titel' of 'titel', maar het kan ook een museumbeschrijving zijn (dit is een titel geworden tijdens de DAAN migratie)"@nl ,
                               "the type of the title. Mostly this is simply 'gegeven titel' (given title), but sometimes it can also be a museum description (which was turned into a title during the DAAN migration)"@en ;
                  rdfs:label "has title type"@en ,
                             "heeft type titel"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/inCollectionsGroup
nisv:inCollectionsGroup rdf:type owl:DatatypeProperty ;
                        rdfs:domain nisv:Program ;
                        rdfs:range xsd:string ;
                        rdfs:comment "de groep van collecties waar dit programma onder valt, bijv. publieke omroepen, commerciele omroepen"@nl ,
                                     "the collection group for this programme, e.g. 'public service',  'commercial broadcasters'"@en ;
                        rdfs:label "is in collectiegroep"@nl ,
                                   "is in collections group"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/isPartOfCatalogue
nisv:isPartOfCatalogue rdf:type owl:DatatypeProperty ;
                       rdfs:domain nisv:Program ;
                       rdfs:range xsd:string ;
                       rdfs:comment "de Beeld en Geluid catalogus waar dit programma/foto/object onderdeel van is"@nl ,
                                    "the Sound and Vision catalogue that this programme/photo/object belongs to"@en ;
                       rdfs:label "is onderdeel van catalogus"@nl ,
                                  "is part of catalogue"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/isSilent
nisv:isSilent rdf:type owl:DatatypeProperty ;
              rdfs:domain nisv:ArchiveMetadataObject ;
              rdfs:range xsd:string ;
              rdfs:comment "geeft aan dat het audiovisueel object geen geluid heeft"@nl ,
                           "indicates that the audiovisual object has no sound"@en ;
              rdfs:label "is silent"@en ,
                         "is stil"@nl .


###  http://www.beeldengeluid.nl/schema/hasPublishedTitle
<http://www.beeldengeluid.nl/schema/hasPublishedTitle> rdf:type owl:DatatypeProperty ;
                                                       rdfs:domain nisv:PublicationEvent ;
                                                       rdfs:range xsd:string ;
                                                       rdfs:comment "de titel waaronder iets is gepubliceerd"@nl ,
                                                                    "the title under which something is published"@en ;
                                                       rdfs:label "has published title"@en ,
                                                                  "heeft publicatietitel"@nl .


