###  http://data.rdlabs.beeldengeluid.nl/schema/ActingEntity
nisv:ActingEntity rdf:type owl:Class ;
                  rdfs:subClassOf skos:Concept ;
                  rdfs:comment "An entity that is capable of taking action, e.g. a person or organisation"@en ;
                  rdfs:label "Acterende entiteit"@nl ,
                             "Acting entity"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/Activity
nisv:Activity rdf:type owl:Class ;
              rdfs:comment "Activiteit in de levenscyklus van een gearchiveerd object"@nl ,
                           "Activity in the lifecycle of the archived object"@en ;
              rdfs:label "Activiteit"@nl ,
                         "Activity"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/ArchiveMetadataObject
nisv:ArchiveMetadataObject rdf:type owl:Class ;
                           rdfs:comment "Archief metadata object, dat beschrijft een gearchiveerde item, zoals een film, muziekstuk of radio-uitzending"@nl ,
                                        "Archive metadata object, that describes an archived item such as a film, piece of music or radio broadcast"@en ;
                           rdfs:label "Archief metadata object"@nl ,
                                      "Archive metadata object"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/BroadcastStation
nisv:BroadcastStation rdf:type owl:Class ;
                      rdfs:subClassOf skos:Concept ;
                      rdfs:comment "A broadcast channel/station. Comes from the GTAA Zender scheme"@en ;
                      rdfs:label "Broadcast station"@en ,
                                 "Zender"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/Broadcaster
nisv:Broadcaster rdf:type owl:Class ;
                 rdfs:subClassOf skos:Concept ;
                 rdfs:comment "A broadcaster. Comes from the NISV internal non-GTAA Zendgemachtigde scheme"@en ;
                 rdfs:label "Broadcaster"@en ,
                            "Zendgemachtigde"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/Carrier
nisv:Carrier rdf:type owl:Class ;
             rdfs:comment "Fysieke drager waar afspeelbare audiovisuele entiteit op staat"@nl ,
                          "Physical carrier on which the playable audiovisual object is stored"@en ;
             rdfs:label "Carrier"@en ,
                        "Drager"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/Cast
nisv:Cast rdf:type owl:Class ;
          rdfs:subClassOf nisv:EntityInRole ;
          rdfs:comment "Acteur en het karakter dat de acteur speelt in een programma"@nl ,
                       "Actor and the character that the actor plays in the programme"@en ;
          rdfs:label "Cast"@en ,
                     "Cast"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/Contractor
nisv:Contractor rdf:type owl:Class ;
                rdfs:subClassOf nisv:EntityInRole ;
                rdfs:comment "Commissioner for the production of an individual audiovisual object"@en ,
                             "Opdrachtgever voor productie van een enkel audiovisuele entiteit"@nl ;
                rdfs:label "Opdrachtgever"@nl ,
                           "Production commissioner"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/Creator
nisv:Creator rdf:type owl:Class ;
             rdfs:subClassOf nisv:EntityInRole ;
             rdfs:comment "Creator of an individual audiovisual object"@en ,
                          "Maker van een enkel audiovisuele entiteit"@nl ;
             rdfs:label "Creator"@en ,
                        "Maker"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/EntityInRole
nisv:EntityInRole rdf:type owl:Class ;
                  rdfs:comment "an entity that has played some role in the audiovisual object, they may have contributed to the production, they may appear in the audiovisual object, they may be mentioned in the audiovisual object"@en ;
                  rdfs:label "Entiteit in een rol"@nl ,
                             "Entity in a role"@en .


###  http://data.rdlabs.beeldengeluid.nl/schema/Funder
nisv:Funder rdf:type owl:Class ;
            rdfs:subClassOf nisv:EntityInRole ;
            rdfs:comment "Funder of the production of an individual audiovisual object"@en ,
                         "Subsidiegever voor productie enkele audiovisuele entiteit"@nl ;
            rdfs:label "Funder"@en ,
                       "Subsidiegever"@nl .


###  http://data.rdlabs.beeldengeluid.nl/schema/Genre
nisv:Genre rdf:type owl:Class ;
           rdfs:subClassOf skos:Concept ;
           rdfs:comment "A genre. Comes from the GTAA Genre scheme"@en ;
           rdfs:label "Genre"@en ,
                      "Genre"@nl .


